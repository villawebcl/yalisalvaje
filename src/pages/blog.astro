---
import Layout from "../layouts/Layout.astro";
import Header from "../components/ui/Header.astro";
import Footer from "../components/ui/Footer.astro";
import { supabase } from "../lib/supabaseClient";
import { buildOptimizedImageUrl, buildResponsiveSrcSet } from "../lib/imageUtils";

const { data: posts, error } = await supabase
  .from("blog_posts")
  .select("id, title, excerpt, image_url, category, published_at")
  .order("published_at", { ascending: false });

if (error) {
  console.error("Error al cargar el blog:", error);
}

const blogPosts = (posts ?? []).map((post) => ({
  ...post,
  image_card_url: buildOptimizedImageUrl(post.image_url, { width: 980, quality: 64 }),
  image_card_srcset: buildResponsiveSrcSet(post.image_url, {
    widths: [420, 680, 920, 1200],
    quality: 62,
  }),
}));
---

<Layout title="Blog | Yali Salvaje">
  <Header />
  <section class="page">
    <div class="container">
      <p class="kicker">Noticias y curiosidades</p>
      <h1>Blog del Humedal</h1>
      <p class="lead">
        Aquí podrás encontrar artículos con imágenes y texto sobre flora, fauna
        y actividades de conservación.
      </p>

      <div class="grid">
        {
          blogPosts.length === 0 ? (
            <div class="empty">
              <p>Aún no hay entradas publicadas.</p>
              <p>Vuelve pronto para leer nuevas historias del humedal.</p>
            </div>
          ) : (
            blogPosts.map((post) => (
              <a class="card card-surface card-hover media-zoom" href={`/blog/${post.id}`}>
                {post.image_card_url && (
                  <div class="card-image">
                    <img
                      src={post.image_card_url}
                      srcset={post.image_card_srcset || undefined}
                      sizes="(max-width: 900px) 100vw, (max-width: 1300px) 50vw, 33vw"
                      alt={post.title}
                      loading="lazy"
                      decoding="async"
                      data-fallback={post.image_url ?? ""}
                      onerror="if(this.dataset.fallback && this.src !== this.dataset.fallback){this.src=this.dataset.fallback;}"
                    />
                  </div>
                )}
                <div class="card-body">
                  {post.category && <p class="tag">{post.category}</p>}
                  <h2>{post.title}</h2>
                  {post.excerpt && <p class="excerpt">{post.excerpt}</p>}
                  {post.published_at && (
                    <p class="date">
                      {new Date(post.published_at).toLocaleDateString("es-CL", {
                        day: "2-digit",
                        month: "long",
                        year: "numeric",
                      })}
                    </p>
                  )}
                </div>
              </a>
            ))
          )
        }
      </div>
    </div>
  </section>
  <Footer />
</Layout>

<style>
  .page {
    padding: 7rem 0 6rem;
  }

  h1 {
    font-family: "Alegreya", serif;
    font-size: clamp(2.5rem, 4vw, 4rem);
    margin: 0 0 0.75rem;
  }

  h2 {
    font-family: "Alegreya", serif;
    font-size: 1.6rem;
    margin: 0 0 0.6rem;
  }

  .kicker {
    text-transform: uppercase;
    letter-spacing: 0.25rem;
    font-size: 0.8rem;
    color: var(--muted);
    margin: 0 0 0.5rem;
  }

  .lead {
    font-size: 1.1rem;
    max-width: 700px;
  }

  .grid {
    display: grid;
    gap: 1.75rem;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    margin-top: 2.5rem;
  }

  .card {
    display: grid;
    cursor: pointer;
    border-radius: var(--radius-card);
    overflow: hidden;
    text-decoration: none;
  }

  .card-image img {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }

  .card-body {
    padding: 1.2rem 1.4rem 1.6rem;
    display: grid;
    gap: 0.5rem;
  }

  .tag {
    text-transform: uppercase;
    letter-spacing: 0.2rem;
    font-size: 0.7rem;
    color: var(--muted);
    margin: 0;
  }

  .excerpt {
    margin: 0;
    color: var(--muted);
  }

  .date {
    margin: 0;
    font-size: 0.9rem;
    color: var(--muted);
  }

  .empty {
    background: var(--paper);
    border-radius: var(--radius);
    padding: 2rem;
    box-shadow: var(--shadow);
    color: var(--muted);
  }

  .empty p {
    margin: 0 0 0.5rem;
  }
</style>
