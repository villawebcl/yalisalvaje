---
import Layout from "../layouts/Layout.astro";
import Header from "../components/ui/Header.astro";
import Footer from "../components/ui/Footer.astro";
import BlogManager from "../components/admin/BlogManager.astro";
import GalleryManager from "../components/admin/GalleryManager.astro";
import "../styles/admin.css";
---

<Layout title="Administración | Yali Salvaje">
  <Header />

  <main class="admin-page">
    <div class="container admin-shell">
      <aside class="admin-sidebar card-surface" aria-label="Navegación de administración">
        <div class="sidebar-head">
          <p class="eyebrow">Panel</p>
          <h1>Administración</h1>
          <div class="auth-status" data-state="checking">
            <span class="status-dot"></span>
            <span class="status-text">Conectando...</span>
          </div>
        </div>

        <nav class="sidebar-nav" role="tablist" aria-label="Secciones">
          <button
            class="sidebar-link active"
            type="button"
            role="tab"
            aria-selected="true"
            aria-controls="view-blog"
            id="tab-blog"
            data-tab="blog"
          >
            <span class="label">Blog</span>
            <span class="desc">Entradas, contenido y portada</span>
          </button>
          <button
            class="sidebar-link"
            type="button"
            role="tab"
            aria-selected="false"
            aria-controls="view-galeria"
            id="tab-galeria"
            data-tab="galeria"
            tabindex="-1"
          >
            <span class="label">Galería</span>
            <span class="desc">Fotos, destacadas y orden</span>
          </button>
        </nav>

        <button class="sidebar-logout" type="button" id="logout">Cerrar sesión</button>
      </aside>

      <section class="admin-content">
        <div id="view-blog" class="view-panel active" role="tabpanel" aria-labelledby="tab-blog">
          <BlogManager />
        </div>

        <div
          id="view-galeria"
          class="view-panel"
          role="tabpanel"
          aria-labelledby="tab-galeria"
          hidden
        >
          <GalleryManager />
        </div>
      </section>
    </div>

    <div class="toast" id="toast" role="status" aria-live="polite"></div>
  </main>

  <Footer />
</Layout>

<script>
  const buttons = Array.from(document.querySelectorAll(".sidebar-link[data-tab]"));
  const views = Array.from(document.querySelectorAll(".view-panel"));

  const switchTab = (tabId) => {
    if (!tabId) return;

    buttons.forEach((btn) => {
      if (!(btn instanceof HTMLElement)) return;
      const isActive = btn.dataset.tab === tabId;
      btn.classList.toggle("active", isActive);
      btn.setAttribute("aria-selected", String(isActive));
      if (isActive) btn.removeAttribute("tabindex");
      else btn.setAttribute("tabindex", "-1");
    });

    views.forEach((view) => {
      const isActive = view.id === `view-${tabId}`;
      view.classList.toggle("active", isActive);
      if (isActive) view.removeAttribute("hidden");
      else view.setAttribute("hidden", "");
    });

    sessionStorage.setItem("admin-tab", tabId);
  };

  buttons.forEach((btn, index) => {
    if (!(btn instanceof HTMLElement)) return;
    btn.addEventListener("click", () => switchTab(btn.dataset.tab));
    btn.addEventListener("keydown", (event) => {
      if (event.key !== "ArrowDown" && event.key !== "ArrowUp") return;
      event.preventDefault();
      const delta = event.key === "ArrowDown" ? 1 : -1;
      const nextIndex = (index + delta + buttons.length) % buttons.length;
      const next = buttons[nextIndex];
      if (next instanceof HTMLElement) {
        next.focus();
        switchTab(next.dataset.tab);
      }
    });
  });

  const lastTab = sessionStorage.getItem("admin-tab") || "blog";
  switchTab(lastTab);
</script>

<script
  define:vars={{
    supabaseUrl: import.meta.env.PUBLIC_SUPABASE_URL,
    supabaseAnonKey: import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
    enableImageTransform: import.meta.env.PUBLIC_ENABLE_SUPABASE_IMAGE_TRANSFORM === "true",
  }}
>
  window.__SUPABASE__ = {
    url: supabaseUrl,
    key: supabaseAnonKey,
  };
  window.__ENABLE_IMAGE_TRANSFORM__ = enableImageTransform;
</script>
<script type="module" src="/scripts/admin.js"></script>

<style>
  .admin-page {
    padding: 1.5rem 0 6rem;
    min-height: 80vh;
  }

  .admin-shell {
    display: grid;
    gap: 1rem;
    align-items: start;
  }

  .admin-sidebar {
    position: sticky;
    top: 86px;
    padding: 1rem;
    border: 1px solid rgba(0, 0, 0, 0.08);
  }

  .sidebar-head {
    display: grid;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .eyebrow {
    margin: 0;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }

  h1 {
    margin: 0;
    font-size: clamp(1.35rem, 2vw, 1.7rem);
  }

  .auth-status {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.8rem;
    color: var(--muted);
    background: var(--paper-2);
    border: 1px solid rgba(0, 0, 0, 0.07);
    border-radius: var(--radius-md);
    padding: 0.35rem 0.6rem;
    width: fit-content;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #c5c9c6;
  }

  .auth-status[data-state="ready"] .status-dot {
    background: #2f6b4c;
  }

  .auth-status[data-state="expired"] .status-dot {
    background: #b23c3c;
  }

  .sidebar-nav {
    display: grid;
    gap: 0.5rem;
  }

  .sidebar-link {
    text-align: left;
    border: 1px solid rgba(0, 0, 0, 0.08);
    background: #fff;
    color: var(--text);
    border-radius: var(--radius-md);
    padding: 0.7rem 0.75rem;
    box-shadow: none;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .sidebar-link:hover {
    transform: none;
    box-shadow: none;
    border-color: rgba(20, 83, 45, 0.35);
  }

  .sidebar-link.active {
    border-color: rgba(20, 83, 45, 0.45);
    background: rgba(20, 83, 45, 0.07);
  }

  .sidebar-link .label {
    display: block;
    font-weight: 700;
    font-size: 0.96rem;
  }

  .sidebar-link .desc {
    display: block;
    margin-top: 0.2rem;
    color: var(--muted);
    font-size: 0.8rem;
    font-weight: 500;
  }

  .sidebar-logout {
    margin-top: 0.85rem;
    width: 100%;
    background: #fff;
    color: #9d3636;
    border: 1px solid rgba(157, 54, 54, 0.25);
    border-radius: var(--radius-md);
    padding: 0.55rem 0.7rem;
    font-weight: 700;
    box-shadow: none;
  }

  .sidebar-logout:hover {
    background: #fff2f2;
    transform: none;
    box-shadow: none;
  }

  .admin-content {
    min-width: 0;
  }

  .view-panel {
    background: var(--paper);
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: var(--radius);
    padding: 1.1rem;
    box-shadow: var(--shadow);
  }

  .toast {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    background: var(--paper);
    color: var(--text);
    padding: 0.8rem 1rem;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    opacity: 0;
    transform: translateY(10px);
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
    z-index: 2000;
    max-width: 320px;
    border: 1px solid rgba(0, 0, 0, 0.08);
  }

  .toast.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .toast[data-status="success"] {
    border-left: 3px solid #2f6b4c;
  }

  .toast[data-status="error"] {
    border-left: 3px solid #b23c3c;
  }

  @media (min-width: 980px) {
    .admin-shell {
      grid-template-columns: 280px minmax(0, 1fr);
      gap: 1rem;
    }
  }
</style>
