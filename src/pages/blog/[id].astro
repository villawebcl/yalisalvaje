---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/ui/Header.astro";
import Footer from "../../components/ui/Footer.astro";
import { supabase } from "../../lib/supabaseClient";
import { buildOptimizedImageUrl } from "../../lib/imageUtils";
import { renderBlogContent } from "../../lib/blogContent";

const id = Astro.params.id;
const { data: post, error } = await supabase
  .from("blog_posts")
  .select("id, title, excerpt, content, image_url, category, published_at")
  .eq("id", id)
  .maybeSingle();

if (error) {
  console.error("Error al cargar el post:", error);
}

if (!post) {
  return Astro.redirect("/blog");
}

const imageUrl = buildOptimizedImageUrl(post.image_url, { width: 1400, quality: 66 });
const contentHtml = renderBlogContent(post.content || "");
---

<Layout title={`${post.title} | Blog | Yali Salvaje`}>
  <Header />
  <section class="post-page">
    <article class="post-shell container card-surface">
      <div class="post-actions">
        <a class="back-button" href="/blog">Volver al blog</a>
      </div>

      {imageUrl && (
        <div class="post-hero media-zoom">
          <img
            src={imageUrl}
            alt={post.title}
            loading="eager"
            decoding="async"
            data-fallback={post.image_url ?? ""}
            onerror="if(this.dataset.fallback && this.src !== this.dataset.fallback){this.src=this.dataset.fallback;}"
          />
        </div>
      )}

      <div class="post-body">
        {post.category && <p class="tag">{post.category}</p>}
        <h1>{post.title}</h1>
        {post.published_at && (
          <p class="date">
            {new Date(post.published_at).toLocaleDateString("es-CL", {
              day: "2-digit",
              month: "long",
              year: "numeric",
            })}
          </p>
        )}
        {post.excerpt && <p class="excerpt">{post.excerpt}</p>}
        <div class="content" set:html={contentHtml}></div>
      </div>
      <div class="post-actions post-actions-bottom">
        <a class="back-button" href="/blog">Volver al blog</a>
      </div>
    </article>
  </section>
  <Footer />
</Layout>

<style>
  .post-page {
    padding: 6.5rem 0 5rem;
  }

  .post-shell {
    overflow: hidden;
    border: 1px solid rgba(14, 26, 18, 0.14);
    background: linear-gradient(180deg, rgba(250, 252, 250, 0.98), rgba(245, 248, 246, 0.98));
  }

  .post-actions {
    padding: 0.9rem 1rem 0;
  }

  .post-actions-bottom {
    padding: 0 1.6rem 1.4rem;
  }

  .back-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 36px;
    padding: 0.4rem 0.9rem;
    border: 1px solid rgba(16, 26, 19, 0.2);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: #1b3525;
    background: rgba(223, 235, 226, 0.85);
    font-weight: 700;
    font-size: 0.92rem;
  }

  .post-hero img {
    width: 100%;
    max-height: 420px;
    object-fit: cover;
  }

  .post-body {
    padding: 1.1rem 1.6rem 1.25rem;
    display: grid;
    gap: 0.52rem;
  }

  .tag {
    text-transform: uppercase;
    letter-spacing: 0.2rem;
    font-size: 0.7rem;
    color: var(--muted);
    margin: 0;
  }

  h1 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.8vw, 3rem);
  }

  .date {
    margin: 0;
    color: var(--muted);
    font-size: 0.92rem;
  }

  .excerpt {
    margin: 0.1rem 0 0.15rem;
    color: #33483a;
    font-size: 1rem;
  }

  .content {
    margin-top: 0.12rem;
    font-size: 1.02rem;
    line-height: 1.62;
    color: var(--text);
  }

  .content p {
    margin: 0 0 0.62rem;
  }

  .content h3,
  .content h4,
  .content h5 {
    margin: 0.95rem 0 0.4rem;
    font-family: var(--font-display);
    line-height: 1.2;
  }

  .content h3 {
    font-size: 1.25rem;
  }

  .content h4 {
    font-size: 1.12rem;
  }

  .content ul,
  .content ol {
    margin: 0.2rem 0 0.7rem 1.05rem;
    padding: 0;
  }

  .content li {
    margin: 0.14rem 0;
  }

  .content blockquote {
    margin: 0.35rem 0 0.75rem;
    padding: 0.45rem 0.65rem;
    border-left: 3px solid rgba(20, 83, 45, 0.5);
    background: rgba(20, 83, 45, 0.08);
    color: #203b2a;
  }

  .content code {
    background: rgba(12, 20, 14, 0.08);
    padding: 0.1rem 0.35rem;
    border-radius: 0.22rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    font-size: 0.93em;
  }

  .content a {
    color: #14532d;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .content hr {
    border: 0;
    border-top: 1px solid rgba(0, 0, 0, 0.12);
    margin: 0.7rem 0;
  }

  @media (max-width: 768px) {
    .post-body {
      padding: 0.95rem 1rem 1.05rem;
      gap: 0.45rem;
    }

    .post-actions-bottom {
      padding: 0 1rem 1rem;
    }
  }
</style>
