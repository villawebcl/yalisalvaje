---
import { supabase } from "../../lib/supabaseClient";
import { buildOptimizedImageUrl, buildResponsiveSrcSet } from "../../lib/imageUtils";

const { data: featuredSetting, error: featuredError } = await supabase
  .from("site_settings")
  .select("value")
  .eq("key", "featured_gallery_limit")
  .maybeSingle();

if (featuredError) {
  console.error("Error al cargar límite de destacadas:", featuredError);
}

const featuredLimit = Math.max(1, Number(featuredSetting?.value) || 6);

const { data: fotos, error } = await supabase
  .from("imagenes")
  .select("id, url_publica, alt_text, descripcion, detalle, destacada_orden")
  .eq("destacada", true)
  .order("destacada_orden", { ascending: true, nullsFirst: false })
  .order("created_at", { ascending: false })
  .limit(featuredLimit);

if (error) {
  console.error("Error al cargar fotos destacadas:", error);
}

const fotosDestacadas = fotos ?? [];
---

<section class="pictures">
  <div class="container">
    <div class="title">
      <p class="kicker">Galería destacada</p>
      <h2>Fotografías del Yali</h2>
    </div>

    {fotosDestacadas.length === 0 ? (
      <div class="empty">
        <p>Aún no hay fotos destacadas.</p>
        <p>Publica imágenes desde el panel para que aparezcan aquí.</p>
      </div>
    ) : (
      <div class="carousel-wrap">
        <div class="carousel-viewport" id="carousel-viewport">
          <div class="carousel-track" id="carousel-track">
            {fotosDestacadas.map((foto, index) => (
              <figure class="carousel-slide">
                <img
                  src={buildOptimizedImageUrl(foto.url_publica, { width: 1000, quality: 72 })}
                  srcset={buildResponsiveSrcSet(foto.url_publica, { widths: [500, 800, 1000], quality: 72 }) || undefined}
                  sizes="(max-width: 768px) 100vw, 780px"
                  alt={foto.alt_text ?? "Fotografía del humedal"}
                  loading={index === 0 ? "eager" : "lazy"}
                  decoding="async"
                />
                <figcaption>
                  <span class="slide-title">{foto.descripcion ?? foto.alt_text ?? "Sin descripción"}</span>
                </figcaption>
              </figure>
            ))}
          </div>
        </div>

        <button class="carousel-btn prev" aria-label="Anterior">&#8249;</button>
        <button class="carousel-btn next" aria-label="Siguiente">&#8250;</button>

        <div class="carousel-dots" aria-hidden="true">
          {fotosDestacadas.map((_, i) => (
            <span class:list={["dot", { active: i === 0 }]} data-index={i}></span>
          ))}
        </div>
      </div>
    )}

    <div class="cta">
      <a class="button" href="/galeria">Ver galería completa</a>
    </div>
  </div>
</section>

<script>
  const viewport = document.getElementById("carousel-viewport") as HTMLElement;
  const track    = document.getElementById("carousel-track") as HTMLElement;
  if (!viewport || !track) throw new Error("carousel not found");

  const slides = Array.from(track.querySelectorAll<HTMLElement>(".carousel-slide"));
  const dots   = Array.from(document.querySelectorAll<HTMLElement>(".carousel-dots .dot"));
  const total  = slides.length;
  let current  = 0;
  let timer: ReturnType<typeof setInterval>;

  // Asigna ancho exacto del viewport a cada slide (evita el corte)
  function setWidths() {
    const w = viewport.offsetWidth;
    slides.forEach(s => { s.style.width = w + "px"; });
    track.style.transform = `translateX(-${current * viewport.offsetWidth}px)`;
  }

  function goTo(index: number) {
    current = ((index % total) + total) % total;
    track.style.transform = `translateX(-${current * viewport.offsetWidth}px)`;
    dots.forEach((d, i) => d.classList.toggle("active", i === current));
  }

  function startAuto() {
    clearInterval(timer);
    timer = setInterval(() => goTo(current + 1), 4500);
  }

  // Init
  setWidths();
  startAuto();

  window.addEventListener("resize", setWidths);

  document.querySelector(".carousel-btn.prev")?.addEventListener("click", () => { goTo(current - 1); startAuto(); });
  document.querySelector(".carousel-btn.next")?.addEventListener("click", () => { goTo(current + 1); startAuto(); });
  dots.forEach((dot, i) => dot.addEventListener("click", () => { goTo(i); startAuto(); }));

  // Swipe táctil
  let startX = 0;
  viewport.addEventListener("touchstart", (e) => { startX = e.touches[0].clientX; }, { passive: true });
  viewport.addEventListener("touchend", (e) => {
    const diff = startX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 40) { goTo(diff > 0 ? current + 1 : current - 1); startAuto(); }
  });

  // Limpia el intervalo al navegar entre páginas
  document.addEventListener("astro:before-swap", () => clearInterval(timer), { once: true });
</script>

<style>
  .pictures {
    background: var(--paper-2);
    padding: 6rem 0;
  }

  .title {
    text-align: center;
    margin-bottom: 2rem;
  }

  .kicker {
    text-transform: uppercase;
    letter-spacing: 0.25rem;
    font-size: 0.8rem;
    margin: 0 0 0.5rem;
    color: var(--muted);
  }

  h2 {
    font-family: "Alegreya", serif;
    font-size: clamp(2rem, 3vw, 3rem);
    margin: 0;
  }

  /* ── Carrusel centrado y más pequeño ── */
  .carousel-wrap {
    position: relative;
    max-width: 780px;
    margin: 0 auto;
    border-radius: 0.6rem;
    overflow: hidden;
    box-shadow: 0 12px 36px rgba(9, 20, 13, 0.18);
  }

  .carousel-viewport {
    width: 100%;
    overflow: hidden;
  }

  .carousel-track {
    display: flex;
    transition: transform 0.55s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }

  .carousel-slide {
    flex-shrink: 0;
    margin: 0;
    position: relative;
    background: #dae4db;
  }

  .carousel-slide img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
  }

  .carousel-slide figcaption {
    position: absolute;
    inset: auto 0 0;
    padding: 2.5rem 1.2rem 1rem;
    background: linear-gradient(0deg, rgba(5, 10, 7, 0.8), transparent);
    color: rgba(255, 255, 255, 0.97);
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.4);
  }

  .slide-title {
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Botones sobre el carrusel ── */
  .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 50%;
    border: none;
    background: rgba(255, 255, 255, 0.88);
    color: var(--accent, #2f6b4c);
    font-size: 1.6rem;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 10px rgba(9, 20, 13, 0.2);
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .carousel-btn.prev { left: 0.75rem; }
  .carousel-btn.next { right: 0.75rem; }

  .carousel-btn:hover {
    background: white;
    transform: translateY(-50%) scale(1.08);
  }

  /* ── Dots ── */
  .carousel-dots {
    position: absolute;
    bottom: 0.75rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.45rem;
    z-index: 10;
  }

  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.4);
    cursor: pointer;
    transition: background 0.3s ease, transform 0.3s ease;
  }

  .dot.active {
    background: white;
    transform: scale(1.4);
  }

  /* ── Empty ── */
  .empty {
    background: var(--paper);
    border-radius: var(--radius);
    padding: 2rem;
    box-shadow: var(--shadow);
    color: var(--muted);
  }
  .empty p { margin: 0 0 0.5rem; }

  /* ── CTA ── */
  .cta {
    margin-top: 2rem;
    display: flex;
    justify-content: center;
  }

  .button {
    background: var(--accent);
    color: white;
    border-radius: 0.32rem;
    padding: 0.9rem 1.8rem;
    text-decoration: none;
    font-weight: 600;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .button:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(47, 107, 76, 0.25);
  }

  @media (max-width: 600px) {
    .carousel-slide img {
      aspect-ratio: 4 / 3;
    }
  }
</style>
