<div class="chat-widget" data-chat-widget>
  <button
    class="chat-trigger"
    type="button"
    aria-haspopup="dialog"
    aria-controls="chat-humedal-modal"
    aria-expanded="false"
    data-chat-open
  >
    Preguntar al asistente
  </button>

  <div class="chat-modal" id="chat-humedal-modal" role="dialog" aria-modal="true" aria-labelledby="chat-title" aria-hidden="true">
    <div class="chat-overlay" data-chat-close></div>
    <section class="chat-panel">
      <header class="chat-header">
        <div>
          <h2 id="chat-title">Asistente del Humedal El Yali</h2>
          <p>Responde dudas sobre el humedal y Yali Salvaje.</p>
        </div>
        <button class="chat-close" type="button" aria-label="Cerrar chat" data-chat-close>
          Cerrar
        </button>
      </header>

      <div class="chat-messages-wrap">
        <div class="chat-messages" data-chat-messages>
          <article class="msg-wrap msg-wrap-assistant">
            <span class="msg-avatar msg-avatar-assistant" aria-hidden="true">IA</span>
            <div class="msg-stack">
              <p class="msg-role">Asistente</p>
              <div class="msg msg-assistant">
                Hola. Puedo ayudarte con preguntas sobre biodiversidad, ubicación e información del Humedal El Yali.
              </div>
            </div>
          </article>
          <div class="chat-suggestions" data-chat-suggestions>
            <p class="suggestions-label">Preguntas frecuentes</p>
            <div class="suggestions-chips">
              <button class="suggestion-chip" type="button" data-question="¿Qué aves migratorias se pueden ver en El Yali?">¿Qué aves migratorias hay?</button>
              <button class="suggestion-chip" type="button" data-question="¿Cómo llegar al Humedal El Yali desde Santiago?">¿Cómo llegar desde Santiago?</button>
              <button class="suggestion-chip" type="button" data-question="¿Cuál es la mejor época del año para visitar El Yali y fotografiar aves?">¿Cuándo es mejor visitar?</button>
              <button class="suggestion-chip" type="button" data-question="¿Qué mamíferos habitan el Humedal El Yali?">¿Qué mamíferos hay?</button>
            </div>
          </div>
        </div>
        <button class="scroll-bottom-btn" type="button" data-scroll-bottom hidden aria-label="Ir al fondo de la conversación">
          ↓ Ir al fondo
        </button>
      </div>

      <form class="chat-form" data-chat-form>
        <label for="chat-input" class="sr-only">Escribe tu pregunta</label>
        <textarea
          id="chat-input"
          name="message"
          rows="1"
          maxlength="600"
          placeholder="Escribe tu pregunta sobre El Yali..."
          required
        ></textarea>
        <div class="chat-actions">
          <div class="chat-actions-left">
            <small class="char-counter" data-char-counter aria-live="polite">0/600</small>
            <small data-chat-status></small>
          </div>
          <button type="submit" data-chat-send>Enviar</button>
        </div>
        <p class="chat-hint">Enter para enviar · Shift+Enter para nueva línea</p>
      </form>
    </section>
  </div>
</div>

<style>
