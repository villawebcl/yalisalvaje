  @media (max-width: 520px) {
    .msg-wrap {
      max-width: 100%;
      grid-template-columns: 26px minmax(0, 1fr);
      gap: 0.45rem;
    }

    .msg-wrap-user {
      grid-template-columns: minmax(0, 1fr) 26px;
    }

