---

---

<div class="panel-header">
    <h2>Publicar entrada</h2>
    <div class="panel-actions">
        <button type="button" class="secondary" id="blog-new"
            >Nueva entrada</button
        >
        <button type="button" class="secondary" id="blog-cancel" hidden
            >Cancelar edición</button
        >
    </div>
</div>

<div class="modal" id="blog-modal" aria-hidden="true">
    <div class="modal-panel">
        <button class="modal-close" type="button" aria-label="Cerrar">×</button>
        <h3 id="blog-modal-title">Nueva entrada</h3>
        <form class="form" id="blog-form" autocomplete="off">
            <input type="hidden" name="post_id" />
            <label>
                Título
                <input
                    type="text"
                    name="titulo"
                    placeholder="Título del artículo"
                    required
                />
            </label>
            <label>
                Categoría
                <input
                    type="text"
                    name="categoria"
                    placeholder="Ej: Biodiversidad"
                    required
                />
            </label>
            <label>
                Extracto
                <textarea
                    name="extracto"
                    rows="3"
                    placeholder="Resumen breve"
                    required></textarea>
            </label>
            <label>
                Contenido
                <div class="editor-layout">
                    <section class="editor-pane">
                        <p class="field-label">Editor Markdown</p>
                        <div class="md-toolbar" role="toolbar" aria-label="Formato Markdown">
                            <button type="button" class="secondary md-btn" data-md-action="h2">H2</button>
                            <button type="button" class="secondary md-btn" data-md-action="h3">H3</button>
                            <button type="button" class="secondary md-btn" data-md-action="bold">Negrita</button>
                            <button type="button" class="secondary md-btn" data-md-action="italic">Cursiva</button>
                            <button type="button" class="secondary md-btn" data-md-action="ul">Lista</button>
                            <button type="button" class="secondary md-btn" data-md-action="ol">Numerada</button>
                            <button type="button" class="secondary md-btn" data-md-action="quote">Cita</button>
                            <button type="button" class="secondary md-btn" data-md-action="link">Enlace</button>
                            <button type="button" class="secondary md-btn" data-md-action="hr">Separador</button>
                        </div>
                        <textarea
                            id="blog-content-input"
                            name="contenido"
                            rows="16"
                            placeholder="Texto completo de la entrada"
                            required></textarea>
                        <p class="md-hint">
                            Atajos: **negrita**, *cursiva*, - listas, 1. listas numeradas, > cita, [texto](https://url)
                        </p>
                    </section>
                    <section class="preview-pane">
                        <p class="field-label">Vista previa</p>
                        <div class="content-preview" id="blog-content-preview"></div>
                    </section>
                </div>
            </label>
            <label>
                Imagen destacada
                <input type="file" name="imagen" accept="image/*" />
            </label>
            <div class="preview compact">
                <div class="preview-media">
                    <img
                        id="blog-preview-image"
                        alt="Previsualización de imagen"
                    />
                </div>
                <div>
                    <p class="tag" id="blog-preview-category">Sin categoría</p>
                    <p class="preview-title" id="blog-preview-title">
                        Título de la entrada
                    </p>
                    <p class="preview-excerpt" id="blog-preview-excerpt">
                        Aquí aparecerá el extracto.
                    </p>
                </div>
            </div>
            <div class="actions">
                <button type="submit" id="blog-submit">Publicar</button>
            </div>
            <p class="note" id="blog-message"></p>
        </form>
    </div>
</div>

<div class="list" id="blog-list"></div>

<style>
    /* Scoped styles moved from admin.astro global styles where specific */
    .panel-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
    }

    .panel-actions {
        display: flex;
        gap: 0.5rem;
    }

    #blog-modal .modal-panel {
        width: min(1320px, 97vw);
        margin-inline: auto;
    }

    #blog-form {
        max-width: none;
        width: 100%;
        gap: 1rem;
    }

    #blog-form > label {
        width: 100%;
    }

    .md-toolbar {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
        margin-top: 0;
        position: sticky;
        top: 0;
        z-index: 8;
        padding: 0.55rem 0.45rem;
        background: linear-gradient(180deg, rgba(245, 248, 246, 0.98), rgba(245, 248, 246, 0.9));
        border: 1px solid rgba(0, 0, 0, 0.08);
        border-radius: var(--radius-md);
        backdrop-filter: blur(3px);
    }

    .md-btn {
        padding: 0.35rem 0.6rem;
        font-size: 0.82rem;
        line-height: 1.1;
        border-radius: var(--radius-sm);
    }

    .md-hint {
        margin: 0.25rem 0 0;
        font-size: 0.82rem;
        color: var(--muted);
    }

    .editor-layout {
        display: grid;
        gap: 0.9rem;
        align-items: stretch;
    }

    .editor-pane,
    .preview-pane {
        background: var(--paper-2);
        border: 1px solid rgba(0, 0, 0, 0.08);
        border-radius: var(--radius-md);
        padding: 0.65rem;
    }

    .editor-pane textarea {
        min-height: 460px;
        max-height: 68vh;
        width: 100%;
        resize: vertical;
    }

    .preview-pane .content-preview {
        min-height: 460px;
        max-height: 68vh;
        overflow: auto;
        background: #fff;
    }

    @media (min-width: 1040px) {
        .editor-layout {
            grid-template-columns: 1.08fr 0.92fr;
        }
    }
</style>
